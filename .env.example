# Environment Variables — Copy this file to .env and fill in your values

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Get these from Railway / Render / Supabase / your hosting provider
DATABASE_URL=postgresql://username:password@host:5432/rm_tracker

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────────────────────────────────────────
# Secret key for admin operations (change this to something random!)
ADMIN_SECRET=admin123

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
# In production, set this to your actual frontend domain
# e.g. https://rm-tracker.netlify.app
FRONTEND_URL=*
